KBO_ANALYZER_OUTPUT_DIR=./output
NAVER_GAME_URLS=

# all (기본) | analyze | predict
KBO_RUN_MODE=all
KBO_DB_PATH=kbo_predictor.db
KBO_BACKFILL_DAYS=30

# Ollama (사용하려면 KBO_USE_OLLAMA=1 로 변경)
KBO_USE_OLLAMA=0
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=60
KBO_OLLAMA_AUTO_MODEL=1

# Claude API (사용하려면 KBO_USE_CLAUDE=1, ANTHROPIC_API_KEY 입력)
KBO_USE_CLAUDE=0
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001
